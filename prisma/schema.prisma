generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  password          String
  name              String?
  createdAt         DateTime           @default(now())
  analyses          Analysis[]
  plantes           Plant[]
  pushSubscriptions PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model Plant {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  nom           String
  notifActives  Boolean    @default(false)
  intervalDays  Int        @default(7)
  dernierRappel DateTime?
  createdAt     DateTime   @default(now())
  analyses      Analysis[]
}

model Analysis {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  photoUrl        String
  espece          String?
  scoreHealth     Int?
  etatGeneral     String?
  problemes       String   @default("[]")
  recommandations String   @default("[]")
  urgence         String?
  isPublic        Boolean  @default(false)
  plantId         String?
  plant           Plant?   @relation(fields: [plantId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
}
